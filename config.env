#!/usr/bin/env bash
# YouTube Focus Watchdog — Configuration
# This file is sourced by watchdog.sh at each execution

# Expiration date — blocking stops after this date (format: YYYY-MM-DD)
# Set during installation by install.sh
EXPIRY_DATE="2026-06-12" # the date when the YouTube Focus license expires 

# Absolute path to the Safari CSS stylesheet
CSS_PATH="/usr/local/etc/youtube-focus/youtube-focus.css"

# MD5 hash of the reference CSS file (used to detect tampering)
# Generated during installation by install.sh
CSS_HASH=""

# YouTube thumbnail CDN domains to block via /etc/hosts
HOSTS_DOMAINS=(
    "i.ytimg.com"
    "i1.ytimg.com"
    "i2.ytimg.com"
    "i3.ytimg.com"
    "i4.ytimg.com"
    "i9.ytimg.com"
    "s.ytimg.com"
    "yt3.ggpht.com"
    "yt4.ggpht.com"
)

# Log file path
LOG_PATH="/var/log/youtube-focus.log"

# Safari preferences plist path (sandboxed since macOS Ventura)
# The actual user home will be resolved at runtime
SAFARI_PLIST_DOMAIN="com.apple.Safari"
SAFARI_CONTAINER_RELATIVE="Library/Containers/com.apple.Safari/Data/Library/Preferences/com.apple.Safari.plist"
